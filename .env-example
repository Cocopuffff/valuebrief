LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=YOUR_API_KEY
LANGSMITH_PROJECT="Value Brief"
LOG_NODE_EXECUTION=false
SUPABASE_CONNECTION_STRING=postgresql://{user}:{password}@{aws-1-region-1.pooler}.supabase.com:6543/postgres

# LLM Provider Keys
GOOGLE_API_KEY=YOUR_API_KEY
DEEPSEEK_API_KEY=YOUR_API_KEY
OPENROUTER_API_KEY=YOUR_API_KEY
ALPHAVANTAGE_API_KEY=YOUR_API_KEY
OPENAI_API_KEY=YOUR_API_KEY

# Hybrid RAG — Embeddings & Vault
EMBEDDING_MODEL=text-embedding-3-small
VAULT_PATH=data/vault
# CURATOR_AGGRESSIVE_THRESHOLD=0.9

# LLM Provider and Model Configuration
# Note: Frontier models are recommended for Bull, Bear, and Judge analysts to ensure 
# high-quality web search, reasoning, and tool calling. Success has been found using 
# Qwen-3.6-plus with 0.2 temperature for strong reasoning at a cost-effective price point.
#
# THINKING=true is only supported with provider=deepseek and thinking-capable models
# such as deepseek-v4-pro. When enabled, the ChatDeepSeekThinking wrapper is used,
# which automatically echoes reasoning_content back to the API on every turn.

# Node/model fit for the current LangGraph workflow:
# - Bull/Bear: Qwen 3.6 Plus via OpenRouter. These are the only nodes
#   that loop through web/news/scrape tools, so prioritize tool calling
#   and source-selection behavior.
# - Judge/Valuation/Curator: DeepSeek V4 Pro direct with thinking enabled.
#   These nodes do synthesis, DCF-assumption reasoning, reconciliation,
#   and vault compression without external web tools.
# - Supervisor/Report Generator: simple/deterministic orchestration in the
#   current code path; Qwen keeps these low-friction if the model is used.
JUDGE_PROVIDER=deepseek
JUDGE_MODEL=deepseek-v4-pro
JUDGE_TEMPERATURE=0.1
JUDGE_THINKING=true

VALUATION_PROVIDER=deepseek
VALUATION_MODEL=deepseek-v4-pro
VALUATION_TEMPERATURE=0.0
VALUATION_THINKING=true

BULL_PROVIDER=openrouter
BULL_MODEL=qwen/qwen3.6-plus
BULL_TEMPERATURE=0.2
BULL_MAX_ITERATIONS=10
BULL_THINKING=false

BEAR_PROVIDER=openrouter
BEAR_MODEL=qwen/qwen3.6-plus
BEAR_TEMPERATURE=0.2
BEAR_MAX_ITERATIONS=10
BEAR_THINKING=false

SUPERVISOR_PROVIDER=openrouter
SUPERVISOR_MODEL=qwen/qwen3.6-plus
SUPERVISOR_TEMPERATURE=0.1
SUPERVISOR_THINKING=false

REPORT_GENERATOR_PROVIDER=openrouter
REPORT_GENERATOR_MODEL=qwen/qwen3.6-plus
REPORT_GENERATOR_TEMPERATURE=0.1
REPORT_GENERATOR_THINKING=false

# Curator Agent
CURATOR_PROVIDER=deepseek
CURATOR_MODEL=deepseek-v4-pro
CURATOR_TEMPERATURE=0.1
CURATOR_THINKING=true
CURATOR_DB_LIMIT_MB=500              # Hard storage cap (default: 500 = Supabase free tier)
CURATOR_AGGRESSIVE_THRESHOLD=0.8    # Fraction of DB_LIMIT_MB before aggressive pruning
CURATOR_CONSOLIDATION_CUTOFF_DAYS=90  # Files older than this are synthesised + archived
